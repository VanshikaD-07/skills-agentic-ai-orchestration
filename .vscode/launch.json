{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Project Pulse Dashboard",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "python3",
      "args": [
        "-m",
        "http.server",
        "8000"
      ],
      "cwd": "${workspaceFolder}/app",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Serving HTTP on .* port ([0-9]+)",
        "uriFormat": "http://localhost:%s/index.html",
        "action": "openExternally"
      }
    }
  ]
}
